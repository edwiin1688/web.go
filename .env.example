# ============================================================
# web.go Environment Variables Example
# Copy to .env and override as needed. Unset variables will fall
# back to the defaults in main.go.
# ============================================================

# ---- HTTP Server ----
SERVER_ADDR=:8080

# ---- Redis ----
REDIS_ADDR=redis-cluster.h1-redis-dev:6379
# Connection pool (optional; defaults: PoolSize=10, MinIdleConns=2)
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE=2

# ---- MSSQL ----
MSSQL_SERVER=daydb-svc.h1-db-dev
MSSQL_PORT=1433
MSSQL_USER=mobile_api
MSSQL_PASSWORD=
MSSQL_DATABASE=HKNetGame_HJ
